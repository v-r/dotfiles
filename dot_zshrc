# Daily backup of zsh history. Refuses to overwrite the backup if the current
# history file shrank to less than half the backup's size (truncation guard).
zsh_history_backup() {
  emulate -L zsh
  local backup="$HOME/.zsh_history.backup"
  local stamp="$HOME/.cache/zsh_history_backup_date"
  local today="$(date +%Y-%m-%d)"
  [[ -f $stamp && "$(<$stamp)" == "$today" ]] && return
  mkdir -p "$HOME/.cache"
  if [[ -f $backup ]]; then
    local cur bak
    cur=$(wc -c <"$HISTFILE") bak=$(wc -c <"$backup")
    if (( cur * 2 < bak )); then
      print -u2 "WARNING: $HISTFILE shrank (${cur}B vs ${bak}B backup) — skipping backup, check for truncation"
      return 1
    fi
  fi
  cp "$HISTFILE" "$backup" && print "$today" >"$stamp"
}
[[ -f $HISTFILE ]] && zsh_history_backup

